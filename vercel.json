{
  "version": 2,
  "name": "pagaska-music-backend",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/upload-avatar.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/upload-avatar",
      "dest": "/api/upload-avatar.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
