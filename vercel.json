{
  "version": 2,
  "name": "pagaska-music-backend",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/upload-avatar.js": {
      "maxDuration": 15
    },
    "api/auth-callback.js": {
      "maxDuration": 15
    },
    "api/auth-check-ip.js": {
      "maxDuration": 10
    },
    "api/auth-me.js": {
      "maxDuration": 10
    },
    "api/auth-google.js": {
      "maxDuration": 10
    },
    "api/auth-logout.js": {
      "maxDuration": 10
    },
    "api/osama-profile.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/upload-avatar",  "dest": "/api/upload-avatar.js" },
    { "src": "/api/auth/google",    "dest": "/api/auth-google.js" },
    { "src": "/api/auth/callback",  "dest": "/api/auth-callback.js" },
    { "src": "/api/auth/check-ip",  "dest": "/api/auth-check-ip.js" },
    { "src": "/api/auth/me",        "dest": "/api/auth-me.js" },
    { "src": "/api/auth/logout",    "dest": "/api/auth-logout.js" },
    { "src": "/api/osama/profile",  "dest": "/api/osama-profile.js" },
    { "src": "/(.*)",               "dest": "/api/index.js" }
  ]
}
