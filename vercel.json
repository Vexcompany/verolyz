{
  "version": 2,
  "name": "pagaska-music-backend",
  "functions": {
    "api/pagaska-notify.js": {
      "maxDuration": 10
    },
    "api/index.js": {
      "maxDuration": 60
    },
    "api/upload-avatar.js": {
      "maxDuration": 15
    },
    "api/auth.js": {
      "maxDuration": 15
    },
    "api/osama-profile.js": {
      "maxDuration": 10
    },
    "api/config.js": {
      "maxDuration": 10
    },
    "api/notifications.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/upload-avatar",
      "dest": "/api/upload-avatar.js"
    },
    {
      "src": "/api/auth/(google|callback|check-ip|me|logout)",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/osama/profile",
      "dest": "/api/osama-profile.js"
    },
    {
      "src": "/api/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/api/pagaska-notify",
      "dest": "/api/pagaska-notify.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
