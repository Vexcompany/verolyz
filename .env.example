# ==================== MONGODB ====================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spotif?retryWrites=true&w=majority

# ==================== WEB PUSH ====================
# Generate these keys at: https://web-push-codelab.glitch.me/
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your-email@example.com

# ==================== ADMIN ====================
# Generate a strong token for admin operations
ADMIN_TOKEN=your_super_secret_admin_token_here

# ==================== SERVER ====================
NODE_ENV=production
PORT=3000

# ==================== FRONTEND ====================
# Add to your frontend .env file
REACT_APP_NOTIFICATION_API_URL=https://your-backend.vercel.app/api
REACT_APP_BACKEND_URL=https://your-backend.vercel.app
